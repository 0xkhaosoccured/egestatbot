# Скопируй этот файл в .env и заполни значения
# cp .env.example .env

# ── Обязательные ────────────────────────────────────────────────────────────

# Токен бота от @BotFather
BOT_TOKEN=

# Твой Telegram ID (узнать: @userinfobot → поле "id")
ADMIN_CHAT_ID=

# ── Опциональные ─────────────────────────────────────────────────────────────

# ID групповых чатов через запятую (для публичных уведомлений без баллов)
# GROUP_CHAT_IDS=

# Предметы для отслеживания через запятую (пусто = все доступные)
# В Docker без TTY все предметы выбираются автоматически
# MONITOR_SUBJECTS=Русский язык,Информатика (КЕГЭ)

# Базовый интервал проверки в секундах (минимум 30, реальный — случайный ±50%)
# CHECK_INTERVAL_BASE=120
